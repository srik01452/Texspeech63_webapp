<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TecSpeech</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1>TecSpeech</h1>
  <p>Convert Tamil Text & PDFs into Speech</p>
</header>

<section class="hero">
  <h2>Learn Smarter with Audio</h2>
  <p>Upload PDFs or enter text and listen anywhere.</p>
</section>

<section class="converter">
  <h3>Text to Speech</h3>

  <textarea id="textInput" placeholder="Paste Tamil text here..."></textarea>

  <input type="file" id="pdfFile" accept=".pdf">

  <div class="buttons">
    <button onclick="convertSpeech()">🔊 Speak</button>
    <button onclick="stopSpeech()">⏹ Stop</button>
  </div>
</section>

<section class="features">
  <h3>Features</h3>
  <ul>
    <li>PDF Upload</li>
    <li>Text to Speech</li>
    <li>Mobile Friendly</li>
    <li>English Interface</li>
    <li>Free to Use</li>
  </ul>
</section>

<footer>
  <p>© 2026 TecSpeech</p>
</footer>

<script src="script.js"></script>
</body>
</html>
